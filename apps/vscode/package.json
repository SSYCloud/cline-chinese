	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished",
		"workspaceContains:evals.env"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"icons": {
			"cline-icon": {
				"description": "cline",
				"default": {
					"fontPath": "assets/icons/cline-bot.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "ClineWalkthrough",
				"title": "欢迎使用 Cline, 你的新编程伙伴",
				"description": "Cline 像开发者一样编码，因为它的思维方式也像开发者一样。以下 5 种方法助您一臂之力:",
				"steps": [
					{
						"id": "welcome",
						"title": "从目标开始，而不仅仅是提示",
						"description": "告诉 Cline 你想要实现的目标。它会像一位真正的合作伙伴一样，为你制定计划、提出问题，然后进行编码。",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "让 Cline 了解您的代码库",
						"description": "将 Cline 指向您的项目。它可以帮助您理解项目，从而做出智能且可感知上下文的更改。",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "始终使用最佳的 AI 模型",
						"description": "Cline 为您提供最先进的 AI，连接顶级模型（Anthropic、Gemini、OpenAI 等）。",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "使用强大的工具 (MCP) 进行扩展",
						"description": "连接到数据库、API 或在 MCP 市场中发现新功能。",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "你始终掌控一切",
						"description": "审核克莱恩的计划和差异。在变更生效前批准。避免意外。",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "cline-shengsuan-ActivityBar",
					"title": "Cline 中文版",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"cline-shengsuan-ActivityBar": [
				{
					"type": "webview",
					"id": "ClineShengsuan.SidebarProvider",
					"name": ""
				}
			]
		},
		"commands": [
			{
				"command": "ClineShengsuan.plusButtonClicked",
				"title": "新任务",
				"icon": "$(add)"
			},
			{
				"command": "ClineShengsuan.mcpButtonClicked",
				"title": "MCP 服务",
				"icon": "$(server)"
			},
			{
				"command": "ClineShengsuan.historyButtonClicked",
				"title": "历史记录",
				"icon": "$(history)"
			},
			{
				"command": "ClineShengsuan.accountButtonClicked",
				"title": "账户",
				"icon": "$(account)"
			},
			{
				"command": "ClineShengsuan.settingsButtonClicked",
				"title": "设置",
				"icon": "$(settings-gear)"
			},
			{
				"command": "ClineShengsuan.dev.createTestTasks",
				"title": "创建测试任务",
				"category": "ClineShengsuan",
				"when": "cline.isDevMode"
			},
			{
				"command": "ClineShengsuan.expireMcpOAuthTokens",
				"title": "使 MCP OAuth 令牌过期（用于测试）",
				"category": "Cline",
				"when": "ClineShengsuan.isDevMode"
			},
			{
				"command": "ClineShengsuan.addToChat",
				"title": "添加到 Cline",
				"category": "Cline"
			},
			{
				"command": "ClineShengsuan.addTerminalOutputToChat",
				"title": "添加到 Cline-中文版",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.focusChatInput",
				"title": "跳转到对话窗口",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.generateGitCommitMessage",
				"title": "生成带有Cline的提交消息",
				"category": "Cline",
				"icon": "$(cline-icon)"
			},
			{
				"command": "ClineShengsuan.abortGitCommitMessage",
				"title": "使用 Cline 生成提交消息 - 停止",
				"category": "ClineShengsuan",
				"icon": "$(debug-stop)"
			},
			{
				"command": "ClineShengsuan.explainCode",
				"title": "Cline 解释代码",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.improveCode",
				"title": "使用 Cline 优化代码",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.reconstructTaskHistory",
				"title": "重建任务历史",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.jupyterGenerateCell",
				"title": "使用 Cline 生成 Jupyter 单元格",
				"category": "ClineShengsuan",
				"icon": "$(sparkle)"
			},
			{
				"command": "ClineShengsuan.jupyterExplainCell",
				"title": "使用 Cline 解释 Jupyter 单元格",
				"category": "ClineShengsuan",
				"icon": "$(question)"
			},
			{
				"command": "ClineShengsuan.jupyterImproveCell",
				"title": "使用 Cline 优化 Jupyter 单元格",
				"category": "ClineShengsuan",
				"icon": "$(lightbulb)"
			},
			{
				"command": "ClineShengsuan.openWalkthrough",
				"title": "快速入门",
				"category": "ClineShengsuan"
			},
			{
				"command": "ClineShengsuan.reviewComment.reply",
				"title": "回复",
				"category": "ClineShengsuan",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "ClineShengsuan.reviewComment.addToChat",
				"title": "添加到 Cline 聊天",
				"category": "ClineShengsuan",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == cline-ai-review && !commentIsEmpty"
			},
			{
				"command": "ClineShengsuan.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "ClineShengsuan.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "ClineShengsuan.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "ClineShengsuan.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == ClineShengsuan.SidebarProvider"
				},
				{
					"command": "ClineShengsuan.mcpButtonClicked",
					"group": "navigation@2",
					"when": "view == ClineShengsuan.SidebarProvider"
				},
				{
					"command": "ClineShengsuan.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == ClineShengsuan.SidebarProvider"
				},
				{
					"command": "ClineShengsuan.accountButtonClicked",
					"group": "navigation@5",
					"when": "view == ClineShengsuan.SidebarProvider"
				},
				{
					"command": "ClineShengsuan.settingsButtonClicked",
					"group": "navigation@6",
					"when": "view == ClineShengsuan.SidebarProvider"
				}
			],
			"editor/context": [
				{
					"command": "ClineShengsuan.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "ClineShengsuan.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "ClineShengsuan.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !ClineShengsuan.isGeneratingCommit"
				},
				{
					"command": "ClineShengsuan.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && ClineShengsuan.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "ClineShengsuan.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "ClineShengsuan.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "ClineShengsuan.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "ClineShengsuan.generateGitCommitMessage",
					"when": "config.git.enabled && !ClineShengsuan.isGeneratingCommit"
				},
				{
					"command": "ClineShengsuan.abortGitCommitMessage",
					"when": "config.git.enabled && ClineShengsuan.isGeneratingCommit"
				},
				{
					"command": "ClineShengsuan.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "ClineShengsuan.reviewComment.reply",
					"group": "inline",
					"when": "commentController == cline-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "ClineShengsuan.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == cline-ai-review"
				}
			]
		},
		"configuration": {
			"title": "Cline-中文版",
			"properties": {}
		}
	},
	"scripts": {
		"pk":"npx @vscode/vsce package",
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"compile-standalone": "npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npx npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format --config-path ./biome.jsonc src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && tsc --noEmit && cd webview-ui && tsc --noEmit",
		"lint": "biome lint --config-path ./biome.jsonc --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"format": "biome format --config-path ./biome.jsonc --changed --since main --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --config-path ./biome.jsonc --changed --since main --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --config-path ./biome.jsonc --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"ci:check-all": "npx npm-run-all -p check-types lint format",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone && npm run lint",
		"test": "npx npm-run-all test:unit test:integration",
		"test:integration": "vscode-test",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json mocha",
		"test:coverage": "vscode-test --coverage",
		"test:sca-server": "npx tsx watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "npx tsx scripts/testing-platform-orchestrator.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "node scripts/publish-marketplace.mjs",
		"publish:marketplace:prerelease": "node scripts/publish-marketplace.mjs --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"prepare": "npx husky",
		"docs": "cd docs && npm run dev",
		"docs:check-links": "cd docs && npm run check",
		"docs:rename-file": "cd docs && npm run rename",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook",
		"eval:smoke:run": "npx tsx evals/smoke-tests/run-smoke-tests.ts"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/cline/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
