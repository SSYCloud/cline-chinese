{
	"name": "cline-shengsuan",
	"displayName": "Cline 中文版",
	"description": "Cline 中文汉化版，由胜算云进行汉化，打造国内版的OpenRouter，让中国开发者更方便进行 AI 编程。",
	"version": "3.88.1",
	"icon": "assets/icons/icon.png",
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "shengsuan-cloud"
	},
	"license": "Apache-2.0",
	"publisher": "shengsuan-cloud",
	"repository": {
		"type": "git",
		"url": "https://github.com/SSYCloud/cline-chinese-ssy"
	},
	"homepage": "https://www.shengsuanyun.com/",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
