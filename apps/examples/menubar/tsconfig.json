{
	"extends": "../../../sdk/packages/tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ESNext",
		"paths": {
			"@coohu/agents": ["../../../sdk/packages/agents/src/index.ts"],
			"@coohu/agents/*": [
				"../../../sdk/packages/agents/src/*",
				"../../../sdk/packages/agents/src/*/index.ts"
			],
			"@coohu/core": ["../../../sdk/packages/core/src/index.ts"],
			"@coohu/core/hub/daemon-entry": [
				"../../../sdk/packages/core/src/hub/daemon/entry.ts"
			],
			"@coohu/core/*": [
				"../../../sdk/packages/core/src/*",
				"../../../sdk/packages/core/src/*/index.ts"
			],
			"@coohu/llms": ["../../../sdk/packages/llms/src/index.ts"],
			"@coohu/shared": ["../../../sdk/packages/shared/src/index.ts"],
			"@coohu/shared/storage": [
				"../../../sdk/packages/shared/src/storage/index.ts"
			],
			"@coohu/shared/db": ["../../../sdk/packages/shared/src/db/index.ts"],
			"@coohu/shared/*": [
				"../../../sdk/packages/shared/src/*",
				"../../../sdk/packages/shared/src/*/index.ts"
			]
		}
	},
	"include": ["sidecar/**/*.ts"]
}
