{
	"name": "@coohu/sdk",
	"description": "Cline SDK - user-facing alias for @coohu/core",
	"version": "0.1.3",
	"repository": {
		"type": "git",
		"url": "https://github.com/cline/cline",
		"directory": "sdk/packages/sdk"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun run bun.mts && bun tsc -p tsconfig.build.json",
		"typecheck": "bun tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@coohu/core": "0.1.3"
	},
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"license": "Apache-2.0"
}
